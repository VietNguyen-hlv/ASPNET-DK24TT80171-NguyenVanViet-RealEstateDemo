@model RealEstateWebsite.Models.RealEstate

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5" style="max-width: 900px;">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4" style="border-radius: 20px;">⬅️ Quay lại danh sách</a>

    <div class="card shadow border-0 overflow-hidden" style="border-radius: 15px;">

       <div>
        @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImageUrl != "default-house.jpg")
        {
        <img src="~/images/@Model.ImageUrl"
             class="img-fluid rounded shadow"
             style="max-height: 450px; width: 100%; object-fit: cover;"
             alt="@Model.Title">
        }
        else
        {
            // Mượn hình  online làm demo
        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80" 
             class="img-fluid rounded shadow"
             style="max-height: 450px; width: 100%; object-fit: cover;"
             alt="Hình ảnh phối cảnh bất động sản mẫu">
        }
        </div>

        <div class="card-body p-4">
            <div class="d-flex gap-2 mb-3 align-items-center">
                <span class="badge bg-primary px-3 py-2">@Model.Category?.Name</span>
                @if (Model.IsVIP)
                {
                    <span class="badge bg-warning text-dark fw-bold px-3 py-2">⭐ TIN VIP NỔI BẬT</span>
                }
            </div>

            <h2 class="fw-bold text-dark mb-3">@Model.Title</h2>

            <p class="text-muted"><i class="bi bi-geo-alt-fill text-danger"></i> 📍 <strong>Địa chỉ:</strong> @(string.IsNullOrEmpty(Model.AddressNumber) ? "Chưa cập nhật cụ thể" : Model.AddressNumber)</p>

            <hr class="my-4">

            <div class="row text-center bg-light py-3 my-4 mx-0 rounded-3 border">
                <div class="col-4 border-end">
                    <h6 class="text-muted text-uppercase small fw-bold">Giá bán</h6>
                    <span class="text-danger fw-bold fs-4">@Model.Price.ToString("N0") VNĐ</span>
                </div>
                <div class="col-4 border-end">
                    <h6 class="text-muted text-uppercase small fw-bold">Diện tích</h6>
                    <span class="text-dark fw-bold fs-4">📐 @Model.Area m²</span>
                </div>
                <div class="col-4">
                    <h6 class="text-muted text-uppercase small fw-bold">Hướng nhà</h6>
                    <span class="text-secondary fw-bold fs-4">🧭 @(string.IsNullOrEmpty(Model.Direction) ? "Chưa rõ" : Model.Direction)</span>
                </div>
            </div>

            <div class="mb-4">
                <h4 class="fw-bold text-dark mb-3">📄 Thông tin mô tả chi tiết</h4>
                <p class="text-muted" style="line-height: 1.8; white-space: pre-line;">
                    @Model.Description
                </p>
            </div>

            <hr class="my-4">

            <div class="text-end text-muted small">
                <span>🗓️ <strong>Ngày đăng:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        </div>
    </div>
</div>