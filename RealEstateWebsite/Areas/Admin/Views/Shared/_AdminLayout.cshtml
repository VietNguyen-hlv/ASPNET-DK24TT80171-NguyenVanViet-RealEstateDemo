<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ Thống Quản Trị</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            overflow-x: hidden;
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
            width: 260px;
            position: fixed;
        }

            .sidebar a {
                color: rgba(255,255,255,0.75);
                text-decoration: none;
                padding: 12px 20px;
                display: block;
            }

                .sidebar a:hover, .sidebar a.active {
                    color: white;
                    background-color: #343a40;
                    border-left: 4px solid #ffc107;
                }

        .main-content {
            margin-left: 260px;
            padding: 30px;
        }
    </style>
</head>
<body>

    <div class="sidebar d-flex flex-column justify-content-between">
        <div>
            <div class="p-3 text-center border-bottom border-secondary">
                <a href="/admin" class="text-decoration-none d-block">
                    <h5 class="text-warning fw-bold text-uppercase mb-0"><i class="fa-solid fa-shield-halved me-1"></i> Danh mục</h5>
                </a>
            </div>

            <div class="mt-3">
                <a class="active" href="/admin"><i class="fa-solid fa-gauge me-2"></i> Tổng quan</a>

                <a href="/admin/RealEstates"><i class="fa-solid fa-house me-2"></i> Quản lý bài đăng</a>

                <a href="/admin/Users"><i class="fa-solid fa-users me-2"></i> Quản lý thành viên</a>
                <a href="/admin/Categories"><i class="fa-solid fa-layer-group me-2"></i> Danh mục bất động sản</a>
            </div>
        </div>
       
        <div class="p-3 border-top border-secondary text-center">
            <a href="/admin/logout" class="text-danger small fw-bold text-decoration-none d-inline-block w-100 py-2">
                <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất hệ thống
            </a>
        </div>
        
    </div>

    <div class="main-content">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>