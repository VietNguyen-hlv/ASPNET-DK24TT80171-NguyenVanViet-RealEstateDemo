@model RealEstateWebsite.Models.RealEstate 

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập Hệ Thống Quản Trị</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #1a1d20; height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { width: 400px; border: none; border-radius: 15px; background: #212529; color: white; box-shadow: 0px 10px 30px rgba(0,0,0,0.5); }
        .form-control { background-color: #2c3034; border: 1px solid #495057; color: white; }
        .form-control:focus { background-color: #2c3034; color: white; border-color: #ffc107; box-shadow: none; }
    </style>
</head>
<body>

    <div class="card login-card p-4">
        <div class="text-center my-3">
            <h3 class="fw-bold text-warning">👑 TRANG QUẢN TRỊ</h3>
            <p class="text-muted small">Vui lòng đăng nhập để tiến hành quản trị</p>
        </div>

        <div class="text-danger small mb-3 text-center" asp-validation-summary="All"></div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div class="mb-3">
                <label class="form-label small text-secondary">Tên đăng nhập</label>
                <input type="text" name="username" class="form-control form-control-lg" required autocomplete="off" />
            </div>

            <div class="mb-4">
                <label class="form-label small text-secondary">Mật khẩu bảo mật</label>
                <input type="password" name="password" class="form-control form-control-lg" required />
            </div>

            <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold mb-3">ĐĂNG NHẬP HỆ THỐNG</button>

            <div class="text-center">
                <a href="/" class="text-muted small text-decoration-none">⬅️ Quay lại trang chủ Web</a>
            </div>
        </form>
    </div>

</body>
</html>