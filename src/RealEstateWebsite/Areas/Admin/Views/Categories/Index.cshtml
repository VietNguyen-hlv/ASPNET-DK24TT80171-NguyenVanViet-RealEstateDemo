@model IEnumerable<RealEstateWebsite.Models.Category>

@{
    ViewData["Title"] = "Danh mục bất động sản";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <div class="d-flex align-items-center gap-3">
        <a href="/admin" class="btn btn-outline-secondary btn-sm fw-bold shadow-sm">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
        </a>
        <h3 class="fw-bold text-dark mb-0">📂 DANH MỤC BẤT ĐỘNG SẢN</h3>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0 bg-white p-4" style="border-radius: 12px;">
            <h5 class="fw-bold mb-3 text-dark">Thêm danh mục mới</h5>
            <form action="/Admin/Categories/Create" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Tên danh mục</label>
                    <input type="text" name="Name" class="form-control" placeholder="Ví dụ: Đất nền, Căn hộ..." required />
                </div>
                <button type="submit" class="btn btn-primary w-100 fw-bold">Thêm mới</button>
            </form>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0 bg-white p-4" style="border-radius: 12px;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 20%;">Mã số</th>
                            <th style="width: 55%;">Tên danh mục</th>
                            <th class="text-center" style="width: 25%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-muted">#@item.Id</td>
                                    <td class="fw-bold text-dark">@item.Name</td>
                                    <td class="text-center">
                                        <form action="/Admin/Categories/Delete/@item.Id" method="post"
                                              onsubmit="return confirm('Xóa danh mục có thể ảnh hưởng đến bài đăng thuộc danh mục này. Bạn chắc chắn muốn xóa?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold py-1 px-3">
                                                Xóa
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">
                                    Chưa có dữ liệu danh mục nào được tạo.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>