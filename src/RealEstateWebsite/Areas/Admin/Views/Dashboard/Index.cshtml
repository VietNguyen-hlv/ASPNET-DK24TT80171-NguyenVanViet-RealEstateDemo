@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml"; 
    ViewData["Title"] = "Trang Chủ Quản Trị";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">📊 HỆ THỐNG THỐNG KÊ TỔNG QUAN</h2>
    <span class="badge bg-secondary p-2">Hôm nay: @DateTime.Now.ToString("dd/MM/yyyy")</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 bg-primary text-white shadow-sm p-4" style="border-radius: 10px;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase mb-1 small text-white-50">Tổng tin đăng</h6>
                    <h2 class="fw-bold mb-0">1,245</h2>
                </div>
                <i class="fa-solid fa-house-circle-check fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-success text-white shadow-sm p-4" style="border-radius: 10px;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase mb-1 small text-white-50">Tin cần duyệt</h6>
                    <h2 class="fw-bold mb-0">18</h2>
                </div>
                <i class="fa-solid fa-clock-rotate-left fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-warning text-dark shadow-sm p-4" style="border-radius: 10px;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase mb-1 small text-dark-50">Thành viên mới</h6>
                    <h2 class="fw-bold mb-0">342</h2>
                </div>
                <i class="fa-solid fa-users fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-danger text-white shadow-sm p-4" style="border-radius: 10px;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase mb-1 small text-white-50">Tin VIP kích hoạt</h6>
                    <h2 class="fw-bold mb-0">45</h2>
                </div>
                <i class="fa-solid fa-star fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 10px;">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-list text-primary me-2"></i> Tin đăng bất động sản mới gửi lên</h5>
    </div>
    <div class="table-responsive p-3">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã tin</th>
                    <th>Tiêu đề tin</th>
                    <th>Loại hình</th>
                    <th>Giá tiền</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#1024</td>
                    <td class="fw-semibold text-primary">Cho thuê căn hộ dịch vụ 1PN full nội thất Phường 2 Đà Lạt</td>
                    <td><span class="badge bg-info text-white">Cho Thuê</span></td>
                    <td>5.5 Triệu/tháng</td>
                    <td><span class="badge bg-warning text-dark">Chờ duyệt</span></td>
                    <td>
                        <button class="btn btn-sm btn-success"><i class="fa-solid fa-check"></i> Duyệt</button>
                        <button class="btn btn-sm btn-danger"><i class="fa-solid fa-trash"></i> Từ chối</button>
                    </td>
                </tr>
                <tr>
                    <td>#1023</td>
                    <td class="fw-semibold text-primary">Bán đất thổ cư mặt tiền đường Bùi Thị Xuân diện tích 120m2</td>
                    <td><span class="badge bg-primary">Nhà Bán</span></td>
                    <td>4.2 Tỷ</td>
                    <td><span class="badge bg-success text-white">Đã hiển thị</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-eye"></i> Xem chi tiết</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>