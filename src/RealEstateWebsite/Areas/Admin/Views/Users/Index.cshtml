@model IEnumerable<RealEstateWebsite.Models.User>

@{
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <div class="d-flex align-items-center gap-3">
        <a href="/admin" class="btn btn-outline-secondary btn-sm fw-bold shadow-sm">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
        </a>
        <h3 class="fw-bold text-dark mb-0">👥 QUẢN LÝ THÀNH VIÊN HỆ THỐNG</h3>
    </div>
    <div class="text-muted small">Tổng số thành viên: <span class="badge bg-success">@Model?.Count()</span></div>
</div>

<div class="card shadow-sm border-0 bg-white p-4" style="border-radius: 12px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Mã số</th>
                    <th>Họ và tên</th>
                    <th>Email / Tài khoản</th>
                    <th>Số điện thoại</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center" style="width: 15%;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-muted">#@item.Id</td>
                            <td class="fw-bold text-dark">@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.PhoneNumber</td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-light text-success border border-success px-2 py-1">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-danger border border-danger px-2 py-1">Đang khóa</span>
                                }
                            </td>
                            <td class="text-center">
                                <form action="/Admin/Users/ToggleStatus/@item.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    @if (item.IsActive)
                                    {
                                        <button type="submit" class="btn btn-sm btn-danger fw-bold py-1 px-2" style="font-size: 11px;"
                                                onsubmit="return confirm('Bạn có chắc chắn muốn khóa tài khoản này?');">
                                            Khóa tài khoản
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-success fw-bold py-1 px-2" style="font-size: 11px;">
                                            Mở khóa
                                        </button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Hệ thống chưa có thành viên nào đăng ký.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>