@model RealEstateWebsite.Models.RealEstate

@{
    ViewData["Title"] = "Chỉnh Sửa Tin Đăng";
}

<div class="container mt-5" style="max-width: 700px;">
    <div class="card shadow p-4" style="border-radius: 12px;">
        <h3 class="text-warning text-center mb-4">✏️ CHỈNH SỬA TIN ĐĂNG BẤT ĐỘNG SẢN</h3>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="WardId" />
            <input type="hidden" asp-for="Status" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="mb-3">
                <label class="form-label fw-bold">Tiêu đề bài đăng</label>
                <input asp-for="Title" class="form-control" required />
            </div>

            <div class="row">
                <div class="col-6 mb-3">
                    <label class="form-label fw-bold">Loại bất động sản</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                </div>
                <div class="col-6 mb-3">
                    <label class="form-label fw-bold">Hướng</label>
                    <input asp-for="Direction" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col-6 mb-3">
                    <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                    <input asp-for="Price" type="number" class="form-control" required />
                </div>
                <div class="col-6 mb-3">
                    <label class="form-label fw-bold">Diện tích (m²)</label>
                    <input asp-for="Area" type="number" step="any" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Địa chỉ</label>
                <input asp-for="AddressNumber" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả chi tiết</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-4 form-check form-switch">
                <input asp-for="IsVIP" class="form-check-input" type="checkbox" id="isVipCheck">
                <label class="form-check-label text-warning fw-bold" for="isVipCheck">⭐ Tin VIP nổi bật</label>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                <button type="submit" class="btn btn-warning px-4 fw-bold text-dark">Lưu Thay Đổi</button>
            </div>
        </form>
    </div>
</div>