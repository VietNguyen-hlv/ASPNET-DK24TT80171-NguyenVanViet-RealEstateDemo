@model IEnumerable<RealEstateWebsite.Models.RealEstate>

@{
    ViewData["Title"] = "Danh Sách Bất Động Sản";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase text-primary" style="letter-spacing: 1px;">Tin Đăng Bất Động Sản Nổi Bật</h2>
        <p class="text-muted">Tìm kiếm không gian sống mơ ước của bạn tại hệ thống của chúng tôi</p>
        <hr class="mx-auto" style="width: 80px; height: 3px; background-color: #0d6efd;" />
    </div>

    <div class="text-center mb-4">
        <a asp-action="Create" class="btn btn-success fw-bold px-4 py-2 shadow-sm" style="border-radius: 20px;">➕ ĐĂNG TIN BẤT ĐỘNG SẢN MỚI</a>
    </div>

    

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0 position-relative @(item.IsVIP ? "card-vip" : "")" style="border-radius: 12px; overflow: hidden; transition: 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.05)!important;">

                        @if (!string.IsNullOrEmpty(item.ImageUrl) && item.ImageUrl != "default-house.jpg")
                        {
                            <img src="~/images/@item.ImageUrl"
                                 class="card-img-top"
                                 style="height: 220px; object-fit: cover;"
                                 alt="@item.Title">
                        }
                        else
                        {
                            <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=600&q=80"
                                 class="card-img-top"
                                 style="height: 220px; object-fit: cover;"
                                 alt="Hình ảnh bất động sản mẫu">
                        }

                       
                        <div class="card-body d-flex flex-column p-4">
                            <span class="badge bg-light text-primary mb-2 align-self-start fw-semibold" style="padding: 6px 10px;">@item.Category?.Name</span>

                            <h5 class="card-title fw-bold text-dark text-truncate mb-2" title="@item.Title">@item.Title</h5>

                            <p class="card-text text-muted small text-truncate-2 mb-4" style="height: 42px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Description
                            </p>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-danger fw-bold fs-5">@item.Price.ToString("N0") VNĐ</span>
                                    <span class="text-secondary fw-semibold">📐 @item.Area m²</span>
                                </div>
                                <div class="text-muted small mb-3">
                                    <span>📍 Hướng: @(string.IsNullOrEmpty(item.Direction) ? "Chưa cập nhật" : item.Direction)</span>
                                </div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn @(item.IsVIP ? "btn-warning text-dark fw-bold" : "btn-outline-primary") w-100" style="border-radius: 8px;">Xem Chi Tiết</a>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm w-50">✏️ Sửa</a>

                            <form asp-action="DeleteConfirmed" asp-route-id="@item.Id" method="post" class="w-50" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tin đăng này không?');">
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100">🗑️ Xóa</button>
                            </form>
                        </div>

                    </div>
                    
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted fs-5">Hiện tại chưa có tin đăng bất động sản nào trong cơ sở dữ liệu.</p>
            </div>
        }
    </div>
</div>

<style>
    /* CSS nhỏ giúp tin VIP có viền vàng cam sang trọng */
    .card-vip {
        border: 2px solid #ffc107 !important;
    }
</style>